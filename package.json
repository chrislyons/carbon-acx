{
  "name": "carbon-acx-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": "20.19.4",
    "pnpm": "10.5.2"
  },
  "scripts": {
    "doctor": "./scripts/bootstrap.sh --check-only",
    "bootstrap": "./scripts/bootstrap.sh",
    "web:data": "python3 scripts/generate_web_calculator_data.py",
    "schema:gen": "pnpm run web:data",
    "dev": "pnpm --filter carbon-acx-web dev",
    "build:web": "pnpm run web:data && pnpm --filter carbon-acx-web install --frozen-lockfile && pnpm --filter carbon-acx-web run build",
    "preview:web": "pnpm --filter carbon-acx-web preview"
  },
  "devDependencies": {
    "tsx": "4.20.6"
  }
}
