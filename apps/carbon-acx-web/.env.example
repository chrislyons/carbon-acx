# Next.js Environment Variables
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend Integration
ACX_DATA_BACKEND=csv
ACX_ARTIFACT_DIR=/Users/chrislyons/dev/carbon-acx/dist/artifacts

# Feature Flags
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_EXPORTS=true
NEXT_PUBLIC_ENABLE_API=true

# World Labs integration (server-only, optional)
WORLD_LABS_API_KEY=
# Optional override for local testing against a proxy or alternate environment.
WORLD_LABS_API_BASE_URL=https://api.worldlabs.ai/marble/v1

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Cloudflare (set automatically by Cloudflare Pages)
# CF_PAGES=1
# CF_PAGES_URL=
# CF_PAGES_COMMIT_SHA=

# Build
NEXT_TELEMETRY_DISABLED=1
